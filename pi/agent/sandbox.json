{
  "network": {
    "allowedDomains": [
      "localhost",
      "127.0.0.1",
      "github.com",
      "*.github.com",
      "*.githubusercontent.com",
      "npmjs.org",
      "*.npmjs.org",
      "registry.yarnpkg.com",
      "pypi.org",
      "*.pypi.org",
      "*.pythonhosted.org",
      "kagi.com",
      "api.search.brave.com",
      "sentry.io",
      "*.sentry.io",
      "datadoghq.com",
      "*.datadoghq.com",
      "datadoghq.eu",
      "*.datadoghq.eu",
      "anthropic.com",
      "*.anthropic.com",
      "openai.com",
      "*.openai.com",
      "chatgpt.com",
      "*.chatgpt.com",
      "*.googleapis.com",
      "todoist.com",
      "*.todoist.com",
      "twist.com",
      "*.twist.com",
      "doist.com",
      "*.doist.com"
    ],
    "deniedDomains": [],
    "allowLocalBinding": true,
    "allowAllUnixSockets": false,
    "allowUnixSockets": ["/tmp", "/private/tmp", "~/.gnupg", "~/.orbstack/run/docker.sock"]
  },
  "filesystem": {
    "denyRead": ["~/.aws"],
    "denyWrite": [".env", ".env.*", "*.pem", "*.key", "~/.ssh"],
    "allowWrite": [".", "/tmp", "/private/tmp", "~/.gnupg", "~/.cache", "~/.docker", "~/.npm"]
  },
  "enableWeakerNestedSandbox": false,
  "enableWeakerNetworkIsolation": true
}
